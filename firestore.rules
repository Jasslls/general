rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir acceso a cualquier documento bajo /users/{userId} si el usuario está autenticado y es el dueño
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // El documento del usuario mismo también debe ser accesible
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
